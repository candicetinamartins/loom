{
  "name": "loom-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Loom — Multi-agent AI IDE built on Eclipse Theia",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/loom-app",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@inversifyjs/common": "1.4.0",
    "@inversifyjs/core": "1.3.5",
    "@theia/core": "1.70.0",
    "@theia/application-package": "1.70.0",
    "@theia/request": "1.70.0",
    "@types/node": "^20.19.39",
    "app-builder-bin": "4.0.0",
    "app-builder-lib": "24.9.1",
    "electron-builder": "24.9.1",
    "typescript": "^5.9.3",
    "webpack": "^5.76.0",
    "webpack-cli": "4.7.0"
  },
  "overrides": {
    "@theia/core": "1.70.0",
    "@theia/application-package": "1.70.0",
    "@theia/request": "1.70.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
