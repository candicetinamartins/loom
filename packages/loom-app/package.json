{
  "name": "@loom/app",
  "version": "0.1.0",
  "description": "Loom IDE — Eclipse Theia application",
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Loom",
        "defaultTheme": "loom-dark"
      }
    }
  },
  "dependencies": {
    "@theia/core": "latest",
    "@theia/editor": "latest",
    "@theia/filesystem": "latest",
    "@theia/git": "latest",
    "@theia/terminal": "latest",
    "@theia/monaco": "latest",
    "@theia/ai-core": "latest",
    "@theia/ai-ide": "latest",
    "@theia/ai-anthropic": "latest",
    "@theia/ai-openai": "latest",
    "@theia/ai-ollama": "latest",
    "@theia/ai-chat": "latest",
    "@theia/debug": "latest",
    "@theia/notebook": "latest",
    "@loom/core": "0.1.0",
    "@loom/tools": "0.1.0",
    "@loom/graph": "0.1.0",
    "@loom/agents": "0.1.0",
    "@loom/ui": "0.1.0",
    "@loom/hooks": "0.1.0",
    "@loom/memory": "0.1.0",
    "@loom/docs": "0.1.0"
  },
  "devDependencies": {
    "@theia/cli": "latest"
  },
  "scripts": {
    "build": "theia build",
    "start": "theia start"
  }
}
