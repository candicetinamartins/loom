{
  "name": "@loom/app",
  "version": "0.1.0",
  "description": "Loom IDE — Eclipse Theia application",
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Loom",
        "defaultTheme": "loom-dark"
      }
    }
  },
  "dependencies": {
    "@theia/core": "1.70.0",
    "@theia/editor": "1.70.0",
    "@theia/filesystem": "1.70.0",
    "@theia/terminal": "1.70.0",
    "@theia/monaco": "1.70.0",
    "@theia/ai-core": "1.70.0",
    "@theia/ai-ide": "1.70.0",
    "@theia/ai-anthropic": "1.70.0",
    "@theia/ai-openai": "1.70.0",
    "@theia/ai-ollama": "1.70.0",
    "@theia/ai-chat": "1.70.0",
    "@theia/debug": "1.70.0",
    "@theia/notebook": "1.70.0",
    "@loom/core": "0.1.0",
    "@loom/tools": "0.1.0",
    "@loom/graph": "0.1.0",
    "@loom/agents": "0.1.0",
    "@loom/ui": "0.1.0",
    "@loom/hooks": "0.1.0",
    "@loom/memory": "0.1.0",
    "@loom/docs": "0.1.0"
  },
  "devDependencies": {
    "@theia/cli": "1.70.0"
  },
  "scripts": {
    "build": "echo 'loom-app: frontend bundle built in loom-electron step'",
    "build:full": "theia build",
    "start": "theia start"
  }
}
