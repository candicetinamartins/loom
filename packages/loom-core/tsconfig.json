{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@theia/ai-core/lib/browser/agent-service": ["./src/stubs/@theia/ai-core/lib/browser/agent-service"],
      "@theia/ai-chat/lib/browser/chat-agent-service": ["./src/stubs/@theia/ai-chat/lib/browser/chat-agent-service"],
      "@theia/terminal/lib/browser/terminal-service": ["./src/stubs/@theia/terminal/lib/browser/terminal-service"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib"]
}
