{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@loom/core": ["../loom-core/lib"],
      "@loom/core/*": ["../loom-core/lib/*"],
      "@loom/graph": ["../loom-graph/lib"],
      "@loom/graph/*": ["../loom-graph/lib/*"],
      "@theia/terminal/lib/browser/terminal-service": ["../loom-core/lib/stubs/@theia/terminal/lib/browser/terminal-service"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib"]
}
