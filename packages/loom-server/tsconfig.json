{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "disableSourceOfProjectReferenceRedirect": true,
    "typeRoots": ["../../node_modules/@types", "../loom-core/src/typings"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib"],
  "references": [
    { "path": "../loom-graph" }
  ]
}
